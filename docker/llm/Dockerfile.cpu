ARG LLAMA_CPP_REF=

# builder
FROM debian:bookworm-slim AS builder
ARG LLAMA_CPP_REF
RUN apt-get update && apt-get install -y --no-install-recommends \
        git cmake build-essential libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src
RUN git clone https://github.com/ggml-org/llama.cpp \
    && cd llama.cpp \
    && if [ -n "$LLAMA_CPP_REF" ]; then git checkout "$LLAMA_CPP_REF"; fi \
    && cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_NATIVE=OFF \
        -DLLAMA_CURL=ON \
        -DBUILD_SHARED_LIBS=OFF \
    && cmake --build build --config Release --target llama-server -j

# runtime
FROM python:3.11-slim-bookworm
# libgomp1: OpenMP (ggml CPU threads). libcurl4: LLAMA_CURL runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgomp1 libcurl4 \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir "pydantic-settings>=2.4,<3"
COPY --from=builder /src/llama.cpp/build/bin/llama-server /opt/llama/bin/llama-server
ENV LLM_EXECUTABLE_PATH=/opt/llama/bin/llama-server
WORKDIR /app
COPY config.py ./config.py
COPY modules/__init__.py ./modules/__init__.py
COPY modules/server/__init__.py ./modules/server/__init__.py
COPY modules/server/llm_server.py ./modules/server/llm_server.py
CMD ["python", "-m", "modules.server.llm_server"]
