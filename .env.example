# App (pipeline and shared settings)
APP_ENABLE_EARCONS=true
APP_WARMUP_ON_INIT=true
APP_CONTINUATION_ENABLED=true
APP_BARGE_IN_ENABLED=true
APP_LOGGING_LEVEL=DEBUG
APP_LOGGING_FORMAT=%(asctime)s %(levelname)s [%(name)s]: %(message)s
APP_DISABLE_HTTP_LOGGING=true

# LLM server
# LLM_EXECUTABLE_PATH is auto-detected per OS (llama-server[.exe]); uncomment to point at a different binary.
# LLM_EXECUTABLE_PATH=llama_cpp_bin/llama-server
LLM_BIND_HOST=127.0.0.1
LLM_SERVER_PORT=43001
LLM_MODEL_PATH=./models/Qwen2.5-3B-Instruct-Q4_K_M.gguf
LLM_CONTEXT_WINDOW=8192
LLM_GPU_LAYERS=0
LLM_FLASH_ATTN=false

# LLM client
LLM_SERVER_HOST=127.0.0.1
LLM_SYSTEM_INSTRUCTIONS=Respond in plain spoken prose only - no markdown, bullet points, headers, bold, emojis, or special characters. Keep responses up to 60 seconds of speaking time, scaled to task complexity.
LLM_TEMPERATURE=0.6
LLM_MAX_ITERATIONS=10
LLM_MODE=agent
LLM_RESPONSE_TIMEOUT=60.0
LLM_HISTORY_ENABLED=true
LLM_HISTORY_MAX_TURNS=3
LLM_HISTORY_IDLE_TIMEOUT_S=120.0

# Tools
TOOLS_ENABLED_MODULES=math_tools,datetime_tools,random_tools,memory_tools
TOOLS_TOOL_TIMEOUT=15.0
TOOLS_MEMORY_SYSTEM_INSTRUCTIONS=You have persistent memory tools. Use store_memory to save facts the user shares about themselves (name, preferences, recurring topics, important dates), proactively and without being asked. Whenever the user asks about themselves or their preferences, or refers to anything they may have told you before, call recall_memory first and answer from what it returns. Never say you don't know a personal detail without searching memory first.
TOOLS_MEMORY_DB_PATH=./assets/memory.db

# Wake word
OWW_MODEL_PATHS=./models/hey_jarvis_v0.1.onnx
OWW_FRAMEWORK=onnx
OWW_THRESHOLD=0.5
OWW_CHUNK_SIZE=1280
OWW_SAMPLE_RATE=16000
OWW_CHANNELS=1
OWW_DTYPE=int16

# STT server
STT_BIND_HOST=127.0.0.1
STT_SERVER_PORT=43002
STT_MODEL_PATH=./models/whisper-base.pt
STT_LANGUAGE=auto
STT_MIN_CHUNK_SIZE=1
STT_WARMUP_AUDIO_PATH=./assets/stt_warmup.wav

# STT client
STT_SERVER_HOST=127.0.0.1
STT_SAMPLE_RATE=16000
STT_CHANNELS=1
STT_DTYPE=int16
STT_BLOCK_SIZE=4000
STT_RESPONSE_TIMEOUT=5.0
STT_CONTINUATION_TIMEOUT=3.0

# TTS server
TTS_BIND_HOST=127.0.0.1
TTS_SERVER_PORT=43003
TTS_MODEL_PATH=./models/en_US-lessac-medium.onnx

# TTS client
TTS_SERVER_HOST=127.0.0.1
TTS_LENGTH_SCALE=1.5
TTS_NOISE_SCALE=1.0
TTS_NOISE_W_SCALE=0.5
TTS_CHUNK_MODE=hybrid
TTS_CHUNK_SIZE=3
TTS_FIRST_CHUNK_MAX_WORDS=5
TTS_PLAYBACK_CHUNK_MS=20
