# ─── Models ────────────────────────────────────────────────────────────────────
# Host path to models directory (mounted as /models in all containers)
MODELS_DIR=./models

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_MODEL_PATH=/models/llm/model.gguf
LLM_SYSTEM_PROMPT=You are a helpful AI voice assistant. Be concise and clear.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.8
LLM_TOP_P=0.95
LLM_N_CTX=4096
LLM_N_THREADS=6

# ─── STT (Whisper) ────────────────────────────────────────────────────────────
WHISPER_MODEL_PATH=/models/whisper/
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ─── Wake Word ────────────────────────────────────────────────────────────────
WAKEWORD_MODEL_PATH=/models/wakeword/model.onnx
WAKEWORD_THRESHOLD=0.3
WAKEWORD_FRAMEWORK=onnx

# ─── TTS (Piper) ─────────────────────────────────────────────────────────────
TTS_MODEL_PATH=/models/tts
TTS_VOICE=en_US-lessac-medium
TTS_SPEAKER_ID=0
TTS_NOISE_SCALE=0.667
TTS_LENGTH_SCALE=1.0

# ─── Audio ────────────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1280
AUDIO_INPUT_DEVICE=-1
AUDIO_OUTPUT_DEVICE=-1
AUDIO_VOLUME=1.0

# ─── Pipeline ─────────────────────────────────────────────────────────────────
SILENCE_DURATION=1.5
MAX_RECORD_SECONDS=15.0
SILENCE_THRESHOLD=0.005

# ─── Agent ────────────────────────────────────────────────────────────────────
AGENT_ENABLED=false

# ─── Chat Continuation ───────────────────────────────────────────────────────
CHAT_CONTINUATION_ENABLED=true
CHAT_CONTINUATION_TIMEOUT=5.0

# ─── Confirmations ───────────────────────────────────────────────────────────
# Comma-separated phrases to TTS-generate as confirmation sounds
CONFIRMATION_PHRASES=mhm,listening,go ahead

# ─── Service URLs (internal docker network, no need to change) ────────────────
WAKEWORD_SERVICE_URL=http://wakeword:8001
STT_SERVICE_URL=http://stt:8002
LLM_SERVICE_URL=http://llm:8003
TTS_SERVICE_URL=http://tts:8004
