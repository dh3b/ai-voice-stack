# Wakeword Configuration
WAKEWORD_MODEL_PATH=/models/wakeword
WAKEWORD_THRESHOLD=0.5
WAKEWORD_PHRASE=hey_jarvis

# STT Configuration
STT_MODEL_PATH=/models/stt
STT_MODEL_SIZE=base
STT_LANGUAGE=en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# LLM Configuration
LLM_MODEL_PATH=/models/llm/model.gguf
LLM_CONTEXT_SIZE=4096
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_TOP_K=40
LLM_MAX_TOKENS=512
LLM_N_GPU_LAYERS=0
LLM_N_THREADS=4
LLM_AGENT_MODE=true
LLM_SYSTEM_PROMPT=You are a helpful voice assistant.

# TTS Configuration
TTS_MODEL_PATH=/models/tts
TTS_VOICE=en_US-lessac-medium
TTS_SPEAKER_ID=0
TTS_SAMPLE_RATE=22050
TTS_NOISE_SCALE=0.667
TTS_LENGTH_SCALE=1.0

# Audio Configuration
AUDIO_INPUT_DEVICE=auto
AUDIO_OUTPUT_DEVICE=auto
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Pipeline Configuration
CHAT_CONTINUATION_ENABLED=true
CHAT_CONTINUATION_TIMEOUT=5.0
SILENCE_THRESHOLD=0.01
SILENCE_DURATION=1.5
MAX_RECORDING_DURATION=30.0

# Service URLs (internal)
WAKEWORD_SERVICE_URL=http://wakeword:8001
STT_SERVICE_URL=http://stt:8002
LLM_SERVICE_URL=http://llm:8003
TTS_SERVICE_URL=http://tts:8004
